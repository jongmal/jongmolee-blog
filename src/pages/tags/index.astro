---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => data.status === 'publish');
const tagCounts = new Map<string, number>();
posts.forEach(p => p.data.tags.forEach(t => tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1)));
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="태그" description="태그별 글 모음">
  <h1 class="text-2xl font-bold mb-8">태그</h1>
  {tags.length === 0 ? (
    <p class="text-gray-500 dark:text-zinc-500 text-center py-20">아직 태그가 없습니다.</p>
  ) : (
    <div class="flex flex-wrap gap-2">
      {tags.map(([tag, count]) => (
        <a
          href={`/tags/${encodeURIComponent(tag)}`}
          class="inline-flex items-baseline gap-1.5 px-3.5 py-1.5 rounded-full border border-gray-200 dark:border-zinc-800 bg-gray-50 dark:bg-zinc-900 hover:bg-gray-100 dark:hover:bg-zinc-800 transition-colors"
        >
          <span class="text-sm">{tag}</span>
          <span class="text-xs text-gray-500 dark:text-zinc-500">{count}</span>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
