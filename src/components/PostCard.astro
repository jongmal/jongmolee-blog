---
interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  series?: string;
  href: string;
}

const { title, description, date, tags = [], series, href } = Astro.props;

const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group">
  <a href={href} class="block p-5 -mx-5 rounded-xl hover:bg-gray-50 dark:hover:bg-zinc-900/50 transition-colors">
    {series && (
      <span class="text-xs font-medium text-primary dark:text-primary-dark mb-1 block">
        📚 {series}
      </span>
    )}
    <h2 class="text-xl font-semibold mb-2 group-hover:text-primary dark:group-hover:text-primary-dark transition-colors">
      {title}
    </h2>
    {description && (
      <p class="text-gray-600 dark:text-zinc-400 text-sm mb-3 line-clamp-2">{description}</p>
    )}
    <div class="flex items-center gap-3">
      <time class="text-xs text-gray-500 dark:text-zinc-500" datetime={date.toISOString()}>
        {formattedDate}
      </time>
      {tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.slice(0, 3).map(tag => (
            <span class="text-xs text-gray-500 dark:text-zinc-500">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
