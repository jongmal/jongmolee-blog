---
import BaseLayout from './BaseLayout.astro';
import SeriesNav from '../components/SeriesNav.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  date: Date;
  tags?: string[];
  series?: string;
  seriesOrder?: number;
  image?: string;
}

const { title, description, date, tags = [], series, seriesOrder, image } = Astro.props;

// 시리즈 포스트 조회
let seriesPosts: any[] = [];
if (series) {
  const allPosts = await getCollection('posts', ({ data }) =>
    data.status === 'publish' && data.series === series
  );
  seriesPosts = allPosts.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
}

const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} image={image}>
  <article>
    <!-- 헤더 -->
    <header class="mb-10">
      {series && (
        <a href={`/series/${encodeURIComponent(series)}`} class="inline-block text-sm font-medium text-primary dark:text-primary-dark mb-3 hover:underline">
          📚 {series}
          {seriesOrder && <span class="text-gray-500 dark:text-zinc-500"> #{seriesOrder}</span>}
        </a>
      )}
      <h1 class="text-3xl font-bold leading-tight mb-4">{title}</h1>
      {description && (
        <p class="text-lg text-gray-600 dark:text-zinc-400 mb-4">{description}</p>
      )}
      <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-zinc-500">
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map(tag => (
            <a
              href={`/tags/${encodeURIComponent(tag)}`}
              class="px-3 py-1 text-xs rounded-full bg-gray-100 dark:bg-zinc-800 text-gray-700 dark:text-zinc-300 hover:bg-gray-200 dark:hover:bg-zinc-700 transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <!-- 시리즈 네비게이션 (상단) -->
    {series && seriesPosts.length > 1 && (
      <SeriesNav
        series={series}
        posts={seriesPosts}
        currentOrder={seriesOrder}
      />
    )}

    <!-- 본문 -->
    <div class="prose dark:prose-invert prose-gray max-w-none
      prose-headings:scroll-mt-20
      prose-a:text-primary dark:prose-a:text-primary-dark prose-a:no-underline hover:prose-a:underline
      prose-code:before:content-none prose-code:after:content-none
      prose-code:bg-gray-100 dark:prose-code:bg-zinc-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
      prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-700
      prose-img:rounded-lg prose-img:mx-auto
    ">
      <slot />
    </div>

    <!-- 시리즈 네비게이션 (하단) -->
    {series && seriesPosts.length > 1 && (
      <div class="mt-16">
        <SeriesNav
          series={series}
          posts={seriesPosts}
          currentOrder={seriesOrder}
          showList
        />
      </div>
    )}
  </article>
</BaseLayout>
